# Domain (base subdomain)
DOMAIN=jaganin.duckdns.org

# DuckDNS token (get it from https://www.duckdns.org)
DUCKDNS_TOKEN=your-duckdns-token-here

# Authelia secrets — generate each with: openssl rand -hex 32
AUTHELIA_JWT_SECRET=change_me_generate_with_openssl_rand_hex_32
AUTHELIA_SESSION_SECRET=change_me_generate_with_openssl_rand_hex_32
AUTHELIA_STORAGE_ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_32

# Authelia OIDC
# HMAC secret — generate with: openssl rand -hex 32
AUTHELIA_OIDC_HMAC_SECRET=change_me_generate_with_openssl_rand_hex_32
# Immich OIDC client secret (plain text — hash it with: docker run --rm authelia/authelia:latest authelia crypto hash generate argon2 --password <secret>)
AUTHELIA_OIDC_IMMICH_SECRET=change_me_random_secret
# Nextcloud OIDC client secret (plain text — hash it with: docker run --rm authelia/authelia:latest authelia crypto hash generate argon2 --password <secret>)
AUTHELIA_OIDC_NEXTCLOUD_SECRET=change_me_random_secret
